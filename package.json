{
  "name": "@usteam/contracts",
  "version": "1.0.0",
  "scripts": {
    "generate": "protoc -I ./proto ./proto/*.proto --plugin=protoc-gen-ts_proto=d:/JS/project/ticket/node_modules/.bin/protoc-gen-ts_proto.cmd --ts_proto_out=./gen --ts_proto_opt=nestJs=true,package=omit"
  },
  "files": [
    "proto",
    "gen"
  ],
  "publishConfig": {
    "access": "public"
  },
  "description": "Protobuf definitions and generated TypeScript types",
  "dependencies": {
    "@nestjs/microservices": "^11.1.11",
    "rxjs": "^7.8.2"
  }
}
